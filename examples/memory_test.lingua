// Memory management test

fn _start(): i32 {
    // Test malloc - allocate 100 bytes
    let addr: i32 = malloc(100);
    
    // Test memset - set 10 bytes to 'A' (65 ASCII)
    memset(addr, 65, 10);
    
    // Load and verify the first value (should be 65 = 'A')
    let val: i32 = load(addr);
    println(val);  // Should print 65
    
    // Store different values at different offsets
    store(addr + 4, 66);  // 'B'
    store(addr + 8, 67);  // 'C'
    
    // Load and verify
    let val2: i32 = load(addr + 4);
    let val3: i32 = load(addr + 8);
    println(val2);  // Should print 66
    println(val3);  // Should print 67
    
    // Test malloc_str - allocate memory for a string
    let str_addr: i32 = malloc_str(addr, 10);
    
    // Return success
    0
}